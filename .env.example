# 通义千问 API Key 配置
# 获取方式：访问 https://dashscope.console.aliyun.com/ 开通服务并创建 API Key
DASHSCOPE_API_KEY=your_api_key_here

# 飞书 webhook 配置（可选）
# 用于推送消息到飞书群
FEISHU_WEBHOOK=your_webhook_url_here

# 服务器端口（可选，默认 5000）
PORT=5000

# 运行环境（可选，默认 production）
FLASK_ENV=production

# 调试模式（生产环境请设为 False）
DEBUG=False
