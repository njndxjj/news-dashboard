# ==================== 服务端口配置 ====================
# 后端服务端口（运行 monitor_app.py）
BACKEND_PORT=5000

# 前端服务端口（运行 Lumos/frontend-new）
FRONTEND_PORT=3000

# 反向代理端口（统一入口）
PROXY_PORT=8080

# ==================== 服务主机配置 ====================
# 如果服务运行在不同主机上，修改以下配置
BACKEND_HOST=localhost
FRONTEND_HOST=localhost

# ==================== 目录配置 ====================
# PID 文件存储目录
PID_DIR=/tmp

# 日志文件存储目录
LOG_DIR=/tmp

# ==================== 定时任务配置 ====================
# 刷新间隔（秒），默认 600 秒 = 10 分钟
REFRESH_INTERVAL=600

# ==================== API 配置 ====================
# 通义千问 API 配置（可选，用于 AI 去重）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 飞书 Webhook 配置（可选，用于推送通知）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_here
