#!/bin/bash
# Lumos 系统定时任务配置
# 此脚本定义了 Lumos 系统的各种定时任务

# 设置环境变量
export PYTHONPATH="/Users/bs-00008898/OpenClaw_Data/Lumos:$PYTHONPATH"
export PATH="/usr/local/bin:/usr/bin:$PATH"

PROJECT_DIR="/Users/bs-00008898/OpenClaw_Data/Lumos"
LOG_DIR="$PROJECT_DIR/logs"
DATA_DIR="$PROJECT_DIR/data"

# 确保日志目录存在
mkdir -p "$LOG_DIR"
mkdir -p "$DATA_DIR"

# 新闻采集任务 - 每10分钟运行一次
*/10 * * * * cd $PROJECT_DIR && /usr/bin/python3 run_crawlers.py >> $LOG_DIR/news_crawl.log 2>&1

# 推荐算法更新 - 每小时运行一次
0 * * * * cd $PROJECT_DIR && /usr/bin/python3 -c "
import sys
sys.path.append('$PROJECT_DIR')
from recommendation_engine import update_recommendations_for_all_users
update_recommendations_for_all_users()
" >> $LOG_DIR/recommendation_update.log 2>&1

# 数据清理任务 - 每天凌晨2点运行
0 2 * * * cd $PROJECT_DIR && /usr/bin/python3 -c "
import sys
sys.path.append('$PROJECT_DIR')
from database import cleanup_old_records
from datetime import datetime, timedelta
cleanup_old_records(datetime.now() - timedelta(days=7))
" >> $LOG_DIR/data_cleanup.log 2>&1

# 系统健康检查 - 每天上午9点运行
0 9 * * * cd $PROJECT_DIR && /usr/bin/python3 -c "
import sys
sys.path.append('$PROJECT_DIR')
from feishu_push import send_health_report
from system_maintenance import SystemMaintenance
maintenance = SystemMaintenance()
report = maintenance.system_health_check()
if report:
    send_health_report(f'系统健康报告\\n时间: {report[\'timestamp\']}\\n磁盘使用率: {report[\'disk_usage\'][\'usage_percent\']}%\\n内存使用率: {report[\'memory_usage\'][\'usage_percent\']}%')
" >> $LOG_DIR/health_check.log 2>&1

# 系统维护 - 每周日凌晨3点运行
0 3 * * 0 cd $PROJECT_DIR && /usr/bin/python3 system_maintenance.py full >> $LOG_DIR/maintenance.log 2>&1

# 日志轮转 - 每天上午3点运行
0 3 * * * cd $PROJECT_DIR && /usr/bin/python3 system_maintenance.py logs >> $LOG_DIR/log_rotation.log 2>&1