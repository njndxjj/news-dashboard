# Environment variables example
# Copy this file to .env and adjust values as needed

# API Base URL - use relative path when using Nginx proxy (recommended for production)
REACT_APP_API_BASE_URL=/

# For direct backend connection (development only)
# REACT_APP_API_BASE_URL=http://localhost:5000

# Backend service URL (for server-side proxy)
BACKEND_URL=http://localhost:5000

# For production with Nginx proxy, you can set:
# BACKEND_URL=