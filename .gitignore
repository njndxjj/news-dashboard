# Git
.git/
.gitignore
.gitattributes

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyo
*.pyd

# 环境配置（重要：包含 API Key）
.env
.env.local
.env.*.local

# 虚拟环境
venv/
env/
ENV/
.venv/

# Node
node_modules/
npm-debug.log
yarn-error.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 测试
test_*.py
test_*.js
*_test.py
coverage/
.htmlcov/

# 日志
*.log
logs/

# 数据（SQLite 数据库和缓存）
data/*.db
data/*.db-*
!data/.gitkeep

# 临时文件
tmp/
temp/
.tmp/
.cowork-temp/

# 构建产物
dist/
build/
*.egg-info/

# Docker
docker-compose.override.yml

# 文档
DEPLOY.md
*.md
!README.md
!LICENSE
!DEPLOYMENT.md
!CHANGELOG.md

# 示例配置保留
!.env.example
!nginx.conf.example
!news-monitor.service

# 敏感文件（包含 Token）- 本地测试用
set-token*.env*
test-no-auth.env*
